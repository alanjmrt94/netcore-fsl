{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NetcoreTEST (file search)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-solution",
      "program": "${workspaceFolder}/NetcoreTEST/bin/Debug/net8.0/NetcoreTEST.dll",
      "args": ["/etc", ".conf", "file", "sync"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "NetcoreTEST (folder search)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-solution",
      "program": "${workspaceFolder}/NetcoreTEST/bin/Debug/net8.0/NetcoreTEST.dll",
      "args": ["/etc", "systemd", "folder", "sync"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
