<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <RootNamespace>NetcoreFSL</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>

    <!-- Versión de la biblioteca (SemVer) — fuente única de verdad -->
    <Version>0.1.0</Version>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <FileVersion>0.1.0.0</FileVersion>
    <InformationalVersion>0.1.0</InformationalVersion>

    <!-- Metadatos del paquete -->
    <Authors>Alan Javier Martinez</Authors>
    <Company>Alan Javier Martinez</Company>
    <Product>NetcoreFSL</Product>
    <Description>Cross-platform, multi-threaded file and directory search library for .NET.</Description>
    <Copyright>Copyright (c) 2021 Alan Javier Martinez</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/alanjmrt94/netcore-fsl</PackageProjectUrl>
    <RepositoryUrl>https://github.com/alanjmrt94/netcore-fsl</RepositoryUrl>
  </PropertyGroup>

</Project>
